# Keep the build context small and secrets out of image layers.
.git
.gitignore
tests/
# Exclude deploy/ EXCEPT the allow-hosts generator, which the image runs at startup.
deploy/*
!deploy/gen_allow_hosts.py
*.md
__pycache__/
*.pyc
.pytest_cache/
.venv-dev/
# Never bake CA / key material into an image (it belongs in a runtime volume).
certs/
.mitmproxy/
*.pem
*.key
