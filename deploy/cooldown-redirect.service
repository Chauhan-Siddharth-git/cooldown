[Unit]
Description=Cooldown transparent redirect (tailscale0 :80/:443 -> mitmproxy 8080)
After=tailscaled.service cooldown-proxy.service
Wants=tailscaled.service
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/sbin/cooldown-redirect.sh up
ExecStop=/usr/local/sbin/cooldown-redirect.sh down
[Install]
WantedBy=multi-user.target
