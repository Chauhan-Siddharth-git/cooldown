# Copy to ".env" (which is gitignored) and fill in — ONLY needed for the
# phone-gating variant (docker-compose.tailscale.yml). The plain onramp needs none of this.

# Tailscale auth key. Generate at: https://login.tailscale.com/admin/settings/keys
# A "reusable", "ephemeral: off" key is fine. Treat it like a password — never commit it.
TS_AUTHKEY=tskey-auth-REPLACE-ME

# Optional: the name this box shows up as in your Tailscale admin console.
TS_HOSTNAME=cooldown-docker

# Optional: your timezone, so the nightly reset / bedtime land at local time.
TZ=America/New_York
